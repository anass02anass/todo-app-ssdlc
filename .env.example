# ============================================================
# Variables de entorno — Copiar a .env y rellenar los valores
# NUNCA subir el archivo .env al repositorio
# ============================================================

# Entorno de ejecución: development | production | test
NODE_ENV=development

# Puerto en el que escucha la aplicación
PORT=3000

# Secreto para firmar las cookies de sesión
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=CAMBIA_ESTE_VALOR_POR_UNO_ALEATORIO_SEGURO

# Ruta del archivo SQLite dentro del contenedor
DB_PATH=/app/data/todo.db
